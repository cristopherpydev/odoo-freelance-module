<odoo>
    <data>
        <!--Actions-->
        <record model="ir.actions.act_window" id="action_freelance_project">
            <field name="name">freelance project window</field>
            <field name="res_model">freelance.project</field>
            <field name="view_mode">list,form</field>
        </record>
        <!--List view-->
        <record model="ir.ui.view" id="freelance_project_list">
        <field name="name">freelance list</field>
        <field name="model">freelance.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
        </record>
        <!--Form view-->
        <record model="ir.ui.view" id="freelance_project_form">
        <field name="name">freelance list</field>
        <field name="model">freelance.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
        </record>
    </data>
</odoo>